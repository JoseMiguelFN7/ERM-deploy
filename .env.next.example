# ==========================================
# CONEXIÓN CON LA API (Laravel)
# ==========================================
# Usada por el navegador del cliente (Ej. http://localhost:8000/api o https://api.midominio.com/api)
NEXT_PUBLIC_API_URL=

# Usada por el servidor de Next.js (SSR) para comunicación interna en Docker (Ej. http://api:80/api)
API_URL_INTERNAL=

# ==========================================
# WEBSOCKETS: LARAVEL REVERB
# ==========================================
# Clave pública de Reverb (Debe coincidir con REVERB_APP_KEY del backend)
NEXT_PUBLIC_REVERB_APP_KEY=

# Host de WebSockets (Ej. localhost en local, api.tudominio.com en prod)
NEXT_PUBLIC_REVERB_HOST=

# Puerto de WebSockets (8080 por defecto, 443 en prod con SSL)
NEXT_PUBLIC_REVERB_PORT=

# Esquema de WebSockets (http para local, https para prod)
NEXT_PUBLIC_REVERB_SCHEME=